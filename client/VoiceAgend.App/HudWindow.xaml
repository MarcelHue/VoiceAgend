<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="VoiceAgend.App.HudWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:views="using:VoiceAgend.App.Views">

    <Grid x:Name="Root" Padding="20,0,24,0" CornerRadius="48">
        <Grid.Background>
            <SolidColorBrush x:Name="BgBrush" Color="#FF101216" />
        </Grid.Background>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <!-- ============ BADGE (left) — 64x64 ============ -->
        <Grid Grid.Column="0" Width="64" Height="64" VerticalAlignment="Center">
            <Ellipse x:Name="BadgeBg" Width="64" Height="64" Opacity="0.18" />
            <Ellipse x:Name="BadgePulseRing" Width="64" Height="64" Opacity="0">
                <Ellipse.RenderTransform>
                    <ScaleTransform x:Name="BadgePulseScale" CenterX="32" CenterY="32" ScaleX="1" ScaleY="1" />
                </Ellipse.RenderTransform>
            </Ellipse>
            <Ellipse x:Name="BadgeDot" Width="18" Height="18" Visibility="Collapsed" />
            <FontIcon x:Name="BadgeIcon" Glyph="" FontSize="28" Visibility="Collapsed" />
            <StackPanel x:Name="BadgeDots" Orientation="Horizontal" Spacing="5"
                        HorizontalAlignment="Center" VerticalAlignment="Center"
                        Visibility="Collapsed">
                <Ellipse x:Name="Dot1" Width="6" Height="6">
                    <Ellipse.RenderTransform>
                        <TranslateTransform x:Name="Dot1T" Y="0" />
                    </Ellipse.RenderTransform>
                </Ellipse>
                <Ellipse x:Name="Dot2" Width="6" Height="6">
                    <Ellipse.RenderTransform>
                        <TranslateTransform x:Name="Dot2T" Y="0" />
                    </Ellipse.RenderTransform>
                </Ellipse>
                <Ellipse x:Name="Dot3" Width="6" Height="6">
                    <Ellipse.RenderTransform>
                        <TranslateTransform x:Name="Dot3T" Y="0" />
                    </Ellipse.RenderTransform>
                </Ellipse>
            </StackPanel>
        </Grid>

        <!-- ============ MAIN CONTENT (state + value) ============ -->
        <StackPanel Grid.Column="1" Margin="18,0,0,0" VerticalAlignment="Center">
            <TextBlock x:Name="StateLabel"
                       FontFamily="ms-appx:///Assets/Fonts/GeistMono-Variable.ttf#Geist Mono"
                       FontSize="14" FontWeight="Medium" CharacterSpacing="180" LineHeight="18" />
            <TextBlock x:Name="StateValue"
                       FontFamily="ms-appx:///Assets/Fonts/Geist-Variable.ttf#Geist"
                       FontSize="18" Foreground="White" Margin="0,4,0,0" LineHeight="24" />
        </StackPanel>

        <!-- ============ MIDDLE (wave / progress) ============ -->
        <Grid Grid.Column="2" Margin="22,0,22,0" VerticalAlignment="Center">
            <views:LiveWaveform x:Name="HudWave" Height="44" Visibility="Collapsed" />
            <ProgressBar x:Name="HudProgress" Height="6" Visibility="Collapsed"
                         IsIndeterminate="True" />
        </Grid>

        <!-- ============ RIGHT ADDON ============ -->
        <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
            <Border x:Name="KbdPill" Visibility="Collapsed"
                    BorderThickness="1" CornerRadius="6" Padding="10,4"
                    VerticalAlignment="Center">
                <TextBlock x:Name="KbdText"
                           FontFamily="ms-appx:///Assets/Fonts/GeistMono-Variable.ttf#Geist Mono"
                           FontSize="15" FontWeight="Medium" />
            </Border>
            <TextBlock x:Name="RightInfo"
                       FontFamily="ms-appx:///Assets/Fonts/GeistMono-Variable.ttf#Geist Mono"
                       FontSize="14" CharacterSpacing="80"
                       VerticalAlignment="Center" />
        </StackPanel>
    </Grid>
</Window>
