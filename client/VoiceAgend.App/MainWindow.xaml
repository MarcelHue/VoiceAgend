<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="VoiceAgend.App.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:tray="using:H.NotifyIcon">

    <Grid Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

        <tray:TaskbarIcon
            x:Name="TrayIcon"
            IconSource="Assets/TrayIdle.ico"
            ToolTipText="VoiceAgend"
            LeftClickCommand="{x:Bind ShowWindowCommand}"
            NoLeftClickDelay="True">
            <tray:TaskbarIcon.ContextFlyout>
                <MenuFlyout>
                    <MenuFlyoutItem x:Name="TrayToggleItem" Command="{x:Bind ToggleCommand}" />
                    <MenuFlyoutSeparator />
                    <MenuFlyoutItem x:Name="TrayShowItem" Command="{x:Bind ShowWindowCommand}" />
                    <MenuFlyoutItem x:Name="TrayQuitItem" Command="{x:Bind QuitCommand}" />
                </MenuFlyout>
            </tray:TaskbarIcon.ContextFlyout>
        </tray:TaskbarIcon>

        <NavigationView
            x:Name="Nav"
            PaneDisplayMode="Left"
            IsBackButtonVisible="Collapsed"
            IsSettingsVisible="False"
            SelectionChanged="OnNavSelectionChanged"
            OpenPaneLength="200"
            IsPaneToggleButtonVisible="True">
            <NavigationView.MenuItems>
                <NavigationViewItem Tag="home" Icon="Document" />
                <NavigationViewItem Tag="profile" Icon="Globe" />
                <NavigationViewItem Tag="settings" Icon="Setting" />
            </NavigationView.MenuItems>

            <Grid>
                <!-- ========================== TRANSKRIPT-SEITE ========================== -->
                <Grid x:Name="HomeView" Padding="24" RowSpacing="14">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" x:Name="HomeTitle"
                                   Style="{StaticResource TitleTextBlockStyle}" />
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                            <TextBlock x:Name="HotkeyEnabledLabel" VerticalAlignment="Center"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <ToggleSwitch x:Name="HotkeyEnabledToggle"
                                          Toggled="OnHotkeyEnabledToggled"
                                          MinWidth="0" />
                        </StackPanel>
                    </Grid>

                    <TextBlock Grid.Row="1" x:Name="HomeStatus"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               TextWrapping="Wrap" />

                    <TextBox Grid.Row="2"
                             x:Name="TranscriptBox"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             IsReadOnly="False"
                             VerticalContentAlignment="Top"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             FontSize="14" />

                    <StackPanel Grid.Row="3" Orientation="Horizontal" Spacing="10">
                        <Button x:Name="BtnCopyTranscript" Click="OnCopyTranscript"
                                Style="{StaticResource AccentButtonStyle}" />
                        <Button x:Name="BtnClearTranscript" Click="OnClearTranscript" />
                        <Button x:Name="BtnHomeToggle" Click="OnTrayToggle" />
                    </StackPanel>
                </Grid>

                <!-- ========================== SERVER-PROFIL ========================== -->
                <ScrollViewer x:Name="ProfileView" Visibility="Collapsed"
                              HorizontalScrollBarVisibility="Disabled"
                              VerticalScrollBarVisibility="Auto">
                    <Grid Padding="24" RowSpacing="14">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" x:Name="ProfileTitle"
                                   Style="{StaticResource TitleTextBlockStyle}" />

                        <TextBlock Grid.Row="1" x:Name="ProfileDescription"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   TextWrapping="Wrap" />

                        <StackPanel Grid.Row="2" Spacing="6" Orientation="Horizontal">
                            <Button x:Name="ProfileLoadButton" Click="OnProfileLoad" />
                            <Button x:Name="ProfileSaveButton" Click="OnProfileSave"
                                    Style="{StaticResource AccentButtonStyle}" />
                            <TextBlock x:Name="ProfileStatus" VerticalAlignment="Center"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        </StackPanel>

                        <StackPanel Grid.Row="3" Spacing="6">
                            <TextBlock x:Name="ProfileModelLabel" />
                            <ComboBox x:Name="ServerModelCombo" Width="500" HorizontalAlignment="Left" />
                        </StackPanel>

                        <StackPanel Grid.Row="4" Spacing="6">
                            <TextBlock x:Name="ProfilePromptLabel" />
                            <TextBox x:Name="ServerPromptBox"
                                     AcceptsReturn="True" TextWrapping="Wrap" Height="80" />
                        </StackPanel>

                        <StackPanel Grid.Row="5" Spacing="6">
                            <TextBlock x:Name="ServerTempLabel" />
                            <Slider x:Name="ServerTempSlider" Minimum="0" Maximum="1" StepFrequency="0.05"
                                    Width="320" HorizontalAlignment="Left"
                                    ValueChanged="OnTempChanged" />
                            <TextBlock x:Name="ProfileTempHint" TextWrapping="Wrap"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        </StackPanel>

                        <TextBlock Grid.Row="6" x:Name="ProfileApiKeyLabel"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   FontStyle="Italic" />

                        <StackPanel Grid.Row="7" Spacing="10" Margin="0,16,0,0">
                            <TextBlock x:Name="ModelsTitle" Style="{StaticResource SubtitleTextBlockStyle}" />
                            <TextBlock x:Name="ModelsDescription"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                            <ItemsControl x:Name="ModelCatalogList" />
                        </StackPanel>
                    </Grid>
                </ScrollViewer>

                <!-- ========================== EINSTELLUNGEN ========================== -->
                <ScrollViewer x:Name="SettingsView" Visibility="Collapsed"
                              HorizontalScrollBarVisibility="Disabled"
                              VerticalScrollBarVisibility="Auto">
                    <Grid Padding="24" RowSpacing="14">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" x:Name="SettingsTitle"
                                   Style="{StaticResource TitleTextBlockStyle}" />

                        <StackPanel Grid.Row="1" Spacing="6">
                            <TextBlock x:Name="ServerUrlLabel" />
                            <TextBox x:Name="ServerUrlBox" LostFocus="OnFieldLostFocus" />
                        </StackPanel>

                        <StackPanel Grid.Row="2" Spacing="6">
                            <TextBlock x:Name="ApiKeyLabel" />
                            <PasswordBox x:Name="ApiKeyBox" LostFocus="OnFieldLostFocus" />
                        </StackPanel>

                        <StackPanel Grid.Row="3" Spacing="6">
                            <TextBlock x:Name="LanguageLabel" />
                            <ComboBox x:Name="LanguageCombo" Width="220" HorizontalAlignment="Left"
                                      SelectionChanged="OnFieldChanged">
                                <ComboBoxItem Tag="" />
                                <ComboBoxItem Tag="de" />
                                <ComboBoxItem Tag="en" />
                            </ComboBox>
                        </StackPanel>

                        <StackPanel Grid.Row="4" Spacing="6">
                            <TextBlock x:Name="MicLabel" />
                            <ComboBox x:Name="MicCombo" Width="500" HorizontalAlignment="Left"
                                      SelectionChanged="OnFieldChanged" />
                        </StackPanel>

                        <StackPanel Grid.Row="5" Spacing="6">
                            <TextBlock x:Name="HotkeyLabel" />
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Button x:Name="HotkeyButton" Click="OnHotkeyRecord" />
                                <TextBlock x:Name="HotkeyDisplay" VerticalAlignment="Center"
                                           Style="{StaticResource BodyStrongTextBlockStyle}" />
                            </StackPanel>
                        </StackPanel>

                        <StackPanel Grid.Row="6" Spacing="6">
                            <TextBlock x:Name="OutputModeLabel" />
                            <ComboBox x:Name="OutputModeCombo" Width="320" HorizontalAlignment="Left"
                                      SelectionChanged="OnFieldChanged">
                                <ComboBoxItem Tag="Clipboard" />
                                <ComboBoxItem Tag="Type" />
                                <ComboBoxItem Tag="Notification" />
                            </ComboBox>
                        </StackPanel>

                        <StackPanel Grid.Row="7" Spacing="10">
                            <CheckBox x:Name="ToastCheck" Click="OnFieldChanged" />

                            <TextBlock x:Name="SoundsTitle" Style="{StaticResource SubtitleTextBlockStyle}" />
                            <Grid ColumnSpacing="12" RowSpacing="6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="220" />
                                    <ColumnDefinition Width="220" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" x:Name="SoundOnStartLabel" VerticalAlignment="Center" />
                                <ComboBox Grid.Row="0" Grid.Column="1" x:Name="SoundStartCombo" HorizontalAlignment="Stretch" SelectionChanged="OnFieldChanged" />
                                <Button Grid.Row="0" Grid.Column="2" x:Name="SoundStartPreview" Click="OnPlayStart" />

                                <TextBlock Grid.Row="1" Grid.Column="0" x:Name="SoundOnStopLabel" VerticalAlignment="Center" />
                                <ComboBox Grid.Row="1" Grid.Column="1" x:Name="SoundStopCombo" HorizontalAlignment="Stretch" SelectionChanged="OnFieldChanged" />
                                <Button Grid.Row="1" Grid.Column="2" x:Name="SoundStopPreview" Click="OnPlayStop" />

                                <TextBlock Grid.Row="2" Grid.Column="0" x:Name="SoundOnDoneLabel" VerticalAlignment="Center" />
                                <ComboBox Grid.Row="2" Grid.Column="1" x:Name="SoundDoneCombo" HorizontalAlignment="Stretch" SelectionChanged="OnFieldChanged" />
                                <Button Grid.Row="2" Grid.Column="2" x:Name="SoundDonePreview" Click="OnPlayDone" />

                                <TextBlock Grid.Row="3" Grid.Column="0" x:Name="SoundOnErrorLabel" VerticalAlignment="Center" />
                                <ComboBox Grid.Row="3" Grid.Column="1" x:Name="SoundErrorCombo" HorizontalAlignment="Stretch" SelectionChanged="OnFieldChanged" />
                                <Button Grid.Row="3" Grid.Column="2" x:Name="SoundErrorPreview" Click="OnPlayError" />
                            </Grid>

                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <TextBlock x:Name="VolumeLabel" VerticalAlignment="Center" Width="200" />
                                <Slider x:Name="VolumeSlider" Width="240" Minimum="0" Maximum="100"
                                        StepFrequency="5" ValueChanged="OnVolumeChanged" />
                            </StackPanel>
                        </StackPanel>

                        <StackPanel Grid.Row="8" Spacing="6" Orientation="Horizontal">
                            <TextBlock x:Name="UiLanguageLabel" VerticalAlignment="Center" />
                            <ComboBox x:Name="UiLanguageCombo" Width="160" SelectionChanged="OnUiLanguageChanged" />
                            <CheckBox x:Name="AutoStartCheck" Click="OnAutoStartToggle" />
                            <CheckBox x:Name="HudEnabledCheck" Click="OnFieldChanged" />
                            <ComboBox x:Name="HudPositionCombo" Width="200" SelectionChanged="OnFieldChanged">
                                <ComboBoxItem Tag="TopLeft" />
                                <ComboBoxItem Tag="TopCenter" />
                                <ComboBoxItem Tag="TopRight" />
                                <ComboBoxItem Tag="MiddleLeft" />
                                <ComboBoxItem Tag="MiddleCenter" />
                                <ComboBoxItem Tag="MiddleRight" />
                                <ComboBoxItem Tag="BottomLeft" />
                                <ComboBoxItem Tag="BottomCenter" />
                                <ComboBoxItem Tag="BottomRight" />
                            </ComboBox>
                            <Button x:Name="HudPreviewButton" Click="OnHudPreview" />
                        </StackPanel>

                        <StackPanel Grid.Row="9" Spacing="6">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <Button x:Name="BtnMinimize" Click="OnMinimizeToTray" />
                                <Button x:Name="BtnOpenLog" Click="OnOpenLog" />
                                <Button x:Name="BtnTestServer" Click="OnTestServer" />
                                <Button x:Name="BtnCheckUpdates" Click="OnCheckUpdates" />
                                <Button x:Name="ApplyUpdateButton"
                                        Click="OnApplyUpdate" Visibility="Collapsed"
                                        Style="{StaticResource AccentButtonStyle}" />
                            </StackPanel>
                            <TextBlock x:Name="UpdateStatus"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <TextBlock x:Name="StatusText" TextWrapping="Wrap" MaxWidth="900"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        </StackPanel>
                    </Grid>
                </ScrollViewer>
            </Grid>
        </NavigationView>
    </Grid>
</Window>
